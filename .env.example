# Copy this to .env and fill in your keys for local development
# Do NOT commit your real .env to git

# Optional: OpenAI API key
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Groq configuration (optional)
GROQ_API_KEY=
GROQ_EMBEDDING_URL=https://api.groq.com/openai/v1/embeddings
GROQ_LLM_MODEL=llama-3.1-8b-instant

# App configuration
DB_PATH=./data/datamind.db
PORT=8080
HOST=0.0.0.0

# Other
MAX_TOKENS=512
EMBEDDING_MODEL=embed-1
