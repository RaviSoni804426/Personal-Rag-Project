# ==========================================
# DataMind Enterprise RAG Configuration Template
# ==========================================

DEBUG=false
HOST=0.0.0.0
PORT=8080
WORKERS=4

# ==================== API Credentials ====================
# Groq API key is required for embedding generation. Get one at console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI API key is optional for GPT-based synthesis. Get one at platform.openai.com
# If not configured, LLMService will fall back to Groq Llama models or context fragments
OPENAI_API_KEY=sk_proj_your_openai_api_key_here

# ==================== Models Configuration ====================
EMBEDDING_MODEL=embed-1
LLM_MODEL=gpt-4o-mini
GROQ_LLM_MODEL=llama-3.1-8b-instant
MAX_TOKENS=512

# ==================== Paths & DB ====================
DB_PATH=./data/datamind.db
CACHE_DIR=./data/cache
UPLOAD_DIR=./data/uploads

# ==================== Search Configurations ====================
DEFAULT_TOP_K=5
MAX_TOP_K=20
SIMILARITY_THRESHOLD=0.0

# ==================== Rate Limits & Security ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
MAX_FILE_SIZE=52428800 # 50MB in bytes

# ==================== Performance & Logging ====================
BATCH_SIZE=10
REQUEST_TIMEOUT=30
LOG_LEVEL=INFO
LOG_FILE=./logs/datamind.log
